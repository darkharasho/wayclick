{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wayclick",
  "version": "0.1.0",
  "identifier": "com.darkharasho.wayclick",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "wayclick",
        "width": 384,
        "height": 600,
        "minWidth": 384,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/darkharasho/wayclick/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNING_PUBLIC_KEY"
    }
  }
}
